<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:backgroundTint="#FAF9F9">

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="437dp"
        android:layout_height="33dp"
        android:background="#EFEFEF"
        android:orientation="vertical"
        tools:layout_editor_absoluteX="16dp"
        tools:layout_editor_absoluteY="514dp">

        <TextView
            android:id="@+id/textView29"
            android:layout_width="52dp"
            android:layout_height="match_parent"
            android:background="#9262F6"
            android:text="study" />

    </LinearLayout>

    <TextView
        android:id="@+id/textView27"
        android:layout_width="48dp"
        android:layout_height="25dp"
        android:layout_marginTop="148dp"
        android:background="#F8F6F6"
        android:paddingHorizontal="6dp"
        android:paddingStart="6dp"
        android:paddingTop="6dp"
        android:text="+topic"
        android:textSize="11sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.231"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="400dp"
        android:layout_height="3dp"
        android:background="#EFEFEF"
        android:orientation="vertical"
        tools:layout_editor_absoluteX="5dp"
        tools:layout_editor_absoluteY="141dp">

    </LinearLayout>

    <TextView
        android:id="@+id/textView21"
        android:layout_width="23dp"
        android:layout_height="56dp"
        android:layout_marginTop="336dp"
        android:text="."
        android:textColor="#5E35B1"
        android:textSize="50sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.056"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/button5"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="80dp"
        android:layout_height="41dp"
        android:layout_marginTop="56dp"
        android:backgroundTint="#F7E4FD"
        android:text="Save"
        android:textColor="#7A3FE3"
        android:textSize="14sp"
        android:textStyle="bold"
        app:cornerRadius="50dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.921"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="#7A3FE3" />

    <TextView
        android:id="@+id/textView12"
        android:layout_width="68dp"
        android:layout_height="75dp"
        android:layout_marginTop="32dp"
        android:text="←"
        android:textColor="#040404"
        android:textSize="53sp"
        android:textStyle="normal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.046"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textView13"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="New Note"
        android:textColor="#0D0D0D"
        android:textSize="21sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="400dp"
        android:layout_height="3dp"
        android:background="#EFEFEF"
        android:orientation="vertical"
        tools:layout_editor_absoluteX="5dp"
        tools:layout_editor_absoluteY="181dp">

    </LinearLayout>

    <EditText
        android:id="@+id/editTextText"
        android:layout_width="367dp"
        android:layout_height="48dp"
        android:layout_marginTop="200dp"
        android:backgroundTint="#DEDDDD"
        android:ems="10"
        android:inputType="text"
        android:text="Note title here..."
        android:textColor="#999797"
        android:textSize="19sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.636"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textView15"
        android:layout_width="368dp"
        android:layout_height="57dp"
        android:layout_marginTop="260dp"
        android:text="Start writing your note here. you can add text,list and more..."
        android:textColor="#ABA8A8"
        android:textSize="16sp"
        android:textStyle="normal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.511"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textView20"
        android:layout_width="23dp"
        android:layout_height="56dp"
        android:layout_marginTop="304dp"
        android:text="."
        android:textColor="#5E35B1"
        android:textSize="50sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.056"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textView22"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="First bullet point"
        android:textColor="#9B9999"
        android:textSize="14sp"
        android:textStyle="bold"
        tools:layout_editor_absoluteX="45dp"
        tools:layout_editor_absoluteY="341dp" />

    <TextView
        android:id="@+id/textView23"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="372dp"
        android:text="Second bullet point"
        android:textColor="#9B6F6F71"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.152"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textView26"
        android:layout_width="48dp"
        android:layout_height="25dp"
        android:background="#F7DEFD"
        android:paddingHorizontal="6dp"
        android:paddingStart="6dp"
        android:paddingTop="6dp"
        android:text="Study"
        android:textSize="11sp"
        android:textStyle="bold"
        tools:layout_editor_absoluteX="22dp"
        tools:layout_editor_absoluteY="148dp" />

</androidx.constraintlayout.widget.ConstraintLayout>